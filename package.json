{
  "name": "devops-learning-lab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "lint:docs": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "check": "npm run format:check && npm run lint:docs && npm run lint && npm run typecheck && npm run test:unit && npm run build && npm run storybook:build"
  },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/vue3-vite": "^10.4.2",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "storybook": "^10.4.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
